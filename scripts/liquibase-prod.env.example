# Copy to liquibase-prod.env in this folder (gitignored) and fill in real values.
# Never commit liquibase-prod.env.
#
# From Supabase: Project Settings → Database → Connection string → URI
# You get something like:
#   postgresql://postgres:[YOUR-PASSWORD]@db.ABCDEF.supabase.co:5432/postgres
#
# Map to the three variables below:
#   - HOWFAR_PROD_LIQUIBASE_USER     → almost always "postgres"
#   - HOWFAR_PROD_LIQUIBASE_PASSWORD → the password (not the brackets)
#   - HOWFAR_PROD_LIQUIBASE_JDBC_URL → JDBC form (see db-migrate-prod.md)

HOWFAR_PROD_LIQUIBASE_JDBC_URL='jdbc:postgresql://db.ABCDEF.supabase.co:5432/postgres?sslmode=require'
HOWFAR_PROD_LIQUIBASE_USER='postgres'
HOWFAR_PROD_LIQUIBASE_PASSWORD='YOUR-PASSWORD-HERE'
