# Copy to .env or add to .env.development.local (loaded by the server in non-production).

DATABASE_URL=postgresql://howfar:howfar@localhost:5432/howfar_dev
MAPBOX_PUB_KEY=
DATABASE_URL=
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# Supabase (browser): Project Settings → API. Prefer publishable key; legacy anon still works.
# Auth → URL Configuration: allow redirect URLs e.g. http://localhost:5173/resetpassword and https://<prod>/resetpassword
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
# VITE_SUPABASE_ANON_KEY= (OLD)

# Supabase (API server only): Project Settings → API Keys → Secret key (sb_secret_...). Verifies user JWTs (e.g. POST /api/routes). Never commit real values.
SUPABASE_URL=
SUPABASE_SECRET_KEY=

# hCaptcha site key (public). Secret goes in Supabase → Authentication → Bot Protection only.
# https://supabase.com/docs/guides/auth/auth-captcha
VITE_HCAPTCHA_SITE_KEY=

# Quick How-Tos:

# To start howfar locally:
# Load necessary environment variables from .env.development.local
# terminal 1. docker-compose up -d
# -> (if needed) npm run db:update
# terminal 2. npm run dev
# terminal 3. npm run server:start

# New migrations/seeds (Liquibase): add db/liquibase/changelog/changes/00X-your-name.sql
# (--liquibase formatted sql + --changeset howfar:00X-id ...), then include that file in
# db/liquibase/changelog/db.changelog-master.yaml (below existing includes). Run: npm run db:update
# from repo root (needs db/liquibase/liquibase.properties; copy from .example).
